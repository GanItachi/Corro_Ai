# =========================================================================
# Corro AI — variables d'environnement
# Copie ce fichier en .env.local pour le dev, ou configure-les dans
# Vercel → Settings → Environment Variables pour la prod.
#
# ⚠️ NE JAMAIS METTRE DE VRAIE CLÉ DANS CE FICHIER : il est commité dans Git.
# Les vraies clés vont uniquement dans .env.local (ignoré par .gitignore).
# =========================================================================

# --- OCR (obligatoire) -----------------------------------------------------
# Clé Gemini gratuite : https://aistudio.google.com/apikey  (pas de CB requis)
# C'est la clé qui fait tourner l'OCR principal.
GEMINI_API_KEY=

# --- OCR : moteurs de repli (optionnels) -----------------------------------
# Si Gemini est saturé/down, /api/ocr bascule automatiquement sur ceux-ci.
# Tu peux n'en configurer aucun — la chaîne s'arrêtera juste à Gemini.

# Groq (vision) — https://console.groq.com/keys (pas de CB)
GROQ_API_KEY=

# OpenRouter (modèles ":free") — https://openrouter.ai/keys (pas de CB)
OPENROUTER_API_KEY=

# --- Sécurité API ---------------------------------------------------------
# Liste blanche d'origines autorisées à appeler /api/ocr, séparées par virgule.
# Empêche les abus si quelqu'un trouve l'URL publique de ton déploiement.
# En local le dev server ajoute http://localhost:3000 automatiquement.
# Exemple : https://copia.vercel.app,https://copia-prod.fr
ALLOWED_ORIGINS=

# --- Modèles OCR (optionnels — override des défauts) -----------------------
# Utile quand un identifiant de modèle devient obsolète (changement fréquent).
# Voir https://ai.google.dev/gemini-api/docs/models pour les noms à jour.
# GEMINI_OCR_MODEL=gemini-2.5-flash
# GEMINI_OCR_FALLBACK_MODEL=gemini-2.5-flash-lite
# GROQ_OCR_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# OPENROUTER_OCR_MODEL=qwen/qwen2.5-vl-72b-instruct:free
